# Copy this file to .env.local and fill in real values to switch the site
# from local mock-data mode to a real Firebase backend.
#
# Leave every FIREBASE_* variable unset to keep running on the built-in
# in-memory mock database (seeded from src/lib/data/seed-jerseys.json),
# which is perfect for local development and previews without any setup.

# --- Session ---
# Any random string of 32+ characters. Generate one with:
#   openssl rand -base64 32
SESSION_SECRET=replace-with-a-random-string-of-at-least-32-characters

# --- Firebase (all three are required together to enable Firestore) ---
# From your Firebase project's service account (Project Settings > Service accounts
# > Generate new private key). Firestore is free on the Spark plan — no card needed.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the \n escape sequences from the downloaded JSON key when pasting here.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Cloudinary (all three are required together to enable photo uploads) ---
# From your Cloudinary dashboard (cloudinary.com/console) — free tier, no card
# needed. Used instead of Firebase Storage, which now requires a paid plan.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
